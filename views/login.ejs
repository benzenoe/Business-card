<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | Bogen.ai Business Cards</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="login-page">
    <div class="login-box">
      <div class="login-logo">
        <img src="https://res.cloudinary.com/dv8wehdd1/image/upload/v1773092815/business-cards/brand/bogen-ai-logo.png" alt="Bogen.ai">
      </div>
      <p class="login-tagline">Digital Business Cards</p>
      <div class="login-divider"></div>

      <% if (error) { %>
        <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
      <% } %>

      <form method="POST" action="/login">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autofocus placeholder="you@example.com">
        </div>
        <div class="form-group" style="margin-bottom:0;">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required placeholder="••••••••">
        </div>
        <button type="submit" class="btn-login" style="margin-top:24px;"><i class="fas fa-sign-in-alt"></i> Sign In</button>
      </form>
    </div>
    <p style="margin-top:24px; font-size:12px; color:rgba(255,255,255,0.3); letter-spacing:0.08em;">POWERED BY BOGEN.AI</p>
  </div>
</body>
</html>
