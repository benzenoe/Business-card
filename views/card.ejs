<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="theme-color" content="<%= card.secondary_color || '#1a3e5c' %>">
  <title><%= card.name %><% if (card.company) { %> | <%= card.company %><% } %></title>
  <meta name="description" content="<%= card.name %><% if (card.title) { %> - <%= card.title %><% } %><% if (card.company) { %> at <%= card.company %><% } %>">

  <meta property="og:title" content="<%= card.name %><% if (card.company) { %> | <%= card.company %><% } %>">
  <meta property="og:description" content="<% if (card.title) { %><%= card.title %><% } %>">
  <meta property="og:type" content="profile">

  <link rel="manifest" href="/manifest/<%= card.slug %>.json">
  <link rel="apple-touch-icon" href="<%= card.headshot_url || '' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

  <style>
    :root {
      --navy: <%= card.secondary_color || '#1a3e5c' %>;
      --bright-blue: <%= card.primary_color || '#00a8e1' %>;
      --bg-start: <%= card.bg_color_start || '#1a3e5c' %>;
      --bg-end: <%= card.bg_color_end || '#0d2233' %>;
      --accent: <%= card.accent_bar_color || '#00a8e1' %>;
      --white: <%= card.light_theme ? '#1a1a1a' : '#ffffff' %>;
      --label-color: <%= card.label_color || card.accent_bar_color || '#00a8e1' %>;
      --info-color: <%= card.info_color || (card.light_theme ? '#1a1a1a' : '#ffffff') %>;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Montserrat', sans-serif;
      background: linear-gradient(180deg, var(--bg-start) 0%, var(--bg-end) 100%);
      min-height: 100vh;
      color: var(--white);
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: 420px;
      margin: 0 auto;
      padding: 40px 24px 60px;
      text-align: center;
    }

    .accent-bar {
      position: fixed;
      left: 0; top: 0;
      width: 4px; height: 100%;
      background: var(--accent);
    }

    /* Brand Header */
    .brand-header { margin-bottom: 24px; }
    .brand-logo { font-size: 32px; font-weight: 700; letter-spacing: 0.02em; color: var(--white); }
    .brand-logo span { color: var(--bright-blue); }

    /* Profile */
    .profile-section { margin-bottom: 32px; }

    .headshot {
      width: 160px; height: 160px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid var(--bright-blue);
      margin-bottom: 24px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      background: rgba(255,255,255,0.1);
    }

    .headshot-placeholder {
      width: 160px; height: 160px;
      border-radius: 50%;
      border: 4px solid var(--bright-blue);
      margin: 0 auto 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 64px;
      color: var(--bright-blue);
      background: rgba(255,255,255,0.05);
    }

    .name { font-size: 28px; font-weight: 300; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; }
    .title { font-size: 14px; font-weight: 500; letter-spacing: 0.05em; color: var(--bright-blue); text-transform: uppercase; margin-bottom: 4px; }
    .company { font-size: 16px; font-weight: 600; letter-spacing: 0.03em; }
    .company span { color: var(--bright-blue); }

    .divider { width: 60px; height: 3px; background: var(--accent); margin: 32px auto; }

    /* Contact */
    .contact-info { margin-bottom: 32px; }

    .contact-item {
      display: flex; align-items: center; justify-content: center;
      gap: 12px; margin-bottom: 16px; font-size: 16px; font-weight: 500;
    }

    .contact-item i { color: var(--bright-blue); width: 24px; font-size: 18px; }
    .contact-item a, .contact-item span { color: var(--info-color); text-decoration: none; transition: color 0.2s; }
    .contact-item a:hover { color: var(--bright-blue); }

    .contact-label { font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--label-color); display: block; margin-bottom: 6px; }

    .contact-item-stacked { display: flex; flex-direction: column; align-items: center; margin-bottom: 20px; }
    .contact-item-stacked .contact-row { display: flex; align-items: center; gap: 12px; }
    .contact-item-stacked .contact-row a { font-size: 18px; font-weight: 500; color: var(--info-color); text-decoration: none; transition: color 0.2s; }
    .contact-item-stacked .contact-row a:hover { color: var(--bright-blue); }

    .whatsapp-badge {
      display: inline-flex; align-items: center; gap: 5px;
      margin-top: 6px;
      background: #25D366; color: #fff;
      padding: 3px 10px; border-radius: 20px;
      font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
      text-decoration: none; transition: filter 0.2s;
    }
    .whatsapp-badge:hover { filter: brightness(0.9); }
    .whatsapp-badge i { font-size: 13px; }

    /* Buttons */
    .cta-button {
      display: block; width: 100%; padding: 18px 32px;
      background: var(--bright-blue); color: #ffffff;
      border: none; border-radius: 4px;
      font-family: 'Montserrat', sans-serif; font-size: 14px;
      font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
      cursor: pointer; transition: all 0.2s; margin-bottom: 16px; text-decoration: none;
    }
    .cta-button:hover { filter: brightness(0.9); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,168,225,0.4); }
    .cta-button i { margin-right: 10px; }

    .cta-secondary {
      display: block; width: 100%; padding: 16px 32px;
      background: transparent; color: var(--white);
      border: 2px solid var(--white); border-radius: 4px;
      font-family: 'Montserrat', sans-serif; font-size: 13px;
      font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
      cursor: pointer; transition: all 0.2s; margin-bottom: 16px;
      text-decoration: none; text-align: center;
    }
    .cta-secondary:hover { background: var(--bright-blue); }
    .cta-secondary i { margin-right: 10px; }

    /* Social */
    .social-links { display: flex; justify-content: center; flex-wrap: wrap; gap: 12px; margin: 32px 0; }

    .social-link {
      width: 46px; height: 46px; border-radius: 50%;
      background: rgba(128,128,128,0.15);
      display: flex; align-items: center; justify-content: center;
      color: var(--white); font-size: 18px; text-decoration: none;
      transition: all 0.2s; border: 1px solid rgba(128,128,128,0.25);
    }
    .social-link:hover { background: var(--bright-blue); border-color: var(--bright-blue); color: #ffffff; transform: translateY(-3px); }

    /* QR */
    .qr-section { margin-top: 40px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.1); }
    .qr-label { font-size: 11px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.7; margin-bottom: 16px; }
    #qrcode { display: inline-block; padding: 12px; background: var(--white); border-radius: 8px; }

    /* Footer */
    .branding { margin-top: 40px; padding-top: 24px; }
    .bogen-logo { font-size: 24px; font-weight: 700; letter-spacing: 0.02em; margin-bottom: 8px; }
    .bogen-logo span { color: var(--bright-blue); }
    .tagline { font-size: 11px; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.6; }

    /* Toast */
    .toast {
      position: fixed; bottom: 30px; left: 50%;
      transform: translateX(-50%) translateY(100px);
      background: var(--bright-blue); color: var(--white);
      padding: 14px 28px; border-radius: 8px;
      font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 500;
      z-index: 1000; opacity: 0; transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    @media (max-width: 360px) {
      .container { padding: 32px 20px 48px; }
      .name { font-size: 24px; }
      .headshot, .headshot-placeholder { width: 140px; height: 140px; }
      .social-links { gap: 10px; }
      .social-link { width: 42px; height: 42px; font-size: 16px; }
    }

    @media (display-mode: standalone) {
      body { padding-top: env(safe-area-inset-top); }
    }

    /* ── Light Theme ── */
    body.light-theme {
      --white: #1a1a1a;
    }
    body.light-theme .cta-button { color: #ffffff !important; }
    body.light-theme #qrcode { background: #ffffff; }
    body.light-theme .cta-secondary {
      border-color: #1a1a1a;
    }
    body.light-theme .cta-secondary:hover {
      background: #1a1a1a;
      color: #ffffff;
    }
    body.light-theme .social-link {
      background: rgba(0,0,0,0.06);
      border-color: rgba(0,0,0,0.15);
    }
    body.light-theme .qr-section {
      border-top-color: rgba(0,0,0,0.12);
    }
    body.light-theme .qr-label { opacity: 1; }
  </style>
</head>
<body class="<%= card.light_theme ? 'light-theme' : '' %>">
  <div class="accent-bar"></div>

  <div class="container">

    <!-- Brand Header -->
    <% if (card.logo_url || card.brand_name) { %>
      <div class="brand-header">
        <% if (card.logo_url) { %>
          <%
            let logoUrl = card.logo_url;
            if (card.logo_invert === 'auto') {
              logoUrl = card.logo_url.replace('/upload/', '/upload/e_negate/');
            } else if (card.logo_invert === 'custom' && card.logo_inverted_url) {
              logoUrl = card.logo_inverted_url;
            }
          %>
          <img src="<%= logoUrl %>" alt="<%= card.brand_name || 'Logo' %>" style="max-height:<%= card.logo_size || 60 %>px; max-width:200px; object-fit:contain;">
        <% } else if (card.brand_name) { %>
          <% if (card.company_highlight && card.brand_name.includes(card.company_highlight)) {
            const parts = card.brand_name.split(card.company_highlight);
          %>
            <div class="brand-logo"><%= parts[0] %><span><%= card.company_highlight %></span><%= parts[1] || '' %></div>
          <% } else { %>
            <div class="brand-logo"><%= card.brand_name %></div>
          <% } %>
        <% } %>
      </div>
    <% } %>

    <!-- Profile -->
    <section class="profile-section">
      <% if (card.headshot_url) { %>
        <img src="<%= card.headshot_url %>" alt="<%= card.name %>" class="headshot">
      <% } else { %>
        <div class="headshot-placeholder"><i class="fas fa-user"></i></div>
      <% } %>

      <h1 class="name"><%= card.name %></h1>
      <% if (card.title) { %><p class="title"><%= card.title %></p><% } %>
      <% if (card.company) { %>
        <p class="company">
          <% if (card.company_highlight && card.company.includes(card.company_highlight)) {
            const parts = card.company.split(card.company_highlight);
          %>
            <%= parts[0] %><span><%= card.company_highlight %></span><%= parts[1] || '' %>
          <% } else { %>
            <%= card.company %>
          <% } %>
        </p>
      <% } %>
    </section>

    <div class="divider"></div>

    <!-- Contact -->
    <section class="contact-info">
      <% const cardPhones = card.phones ? (typeof card.phones === 'string' ? JSON.parse(card.phones) : card.phones) : []; %>
      <% cardPhones.forEach(p => { %>
        <div class="contact-item-stacked">
          <span class="contact-label"><%= p.label %></span>
          <div class="contact-row">
            <i class="fas fa-phone"></i>
            <a href="tel:<%= (p.value || '').replace(/\D/g,'') %>"><%= p.value %></a>
          </div>
          <% if (p.whatsapp) { %>
            <a class="whatsapp-badge" href="https://wa.me/<%= (p.value || '').replace(/\D/g,'') %>" target="_blank">
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          <% } %>
        </div>
      <% }) %>

      <% const cardEmails = card.emails ? (typeof card.emails === 'string' ? JSON.parse(card.emails) : card.emails) : []; %>
      <% cardEmails.forEach(e => { %>
        <div class="contact-item">
          <i class="fas fa-envelope"></i>
          <a href="mailto:<%= e.value %>"><%= e.value %></a>
        </div>
      <% }) %>

      <% const cardWebsites = card.websites ? (typeof card.websites === 'string' ? JSON.parse(card.websites) : card.websites) : (card.website ? [{ label: 'Website', value: card.website }] : []); %>
      <% cardWebsites.forEach(w => { %>
        <div class="contact-item-stacked">
          <span class="contact-label"><%= w.label %></span>
          <div class="contact-row">
            <i class="fas fa-globe"></i>
            <a href="<%= w.value %>" target="_blank"><%= w.value.replace(/^https?:\/\//, '') %></a>
          </div>
        </div>
      <% }) %>
      <% if (card.location) { %>
        <div class="contact-item">
          <i class="fas fa-location-dot"></i>
          <span><%= card.location %></span>
        </div>
      <% } %>
    </section>

    <!-- Save Contact -->
    <button class="cta-button" onclick="downloadVCard()">
      <i class="fas fa-user-plus"></i>Save Contact
    </button>

    <!-- Send My Card -->
    <button class="cta-secondary" onclick="sendCard()">
      <i class="fas fa-paper-plane"></i>Send My Card
    </button>

    <!-- Add to Home Screen (shown by JS based on OS) -->
    <button class="cta-secondary" id="install-btn" style="display:none;" onclick="handleInstall()">
      <i id="install-icon" class="fas fa-plus-square"></i><span id="install-label">Add to Home Screen</span>
    </button>

    <!-- Social Links -->
    <% const socials = [
      { key: 'linkedin', icon: 'fab fa-linkedin-in', label: 'LinkedIn' },
      { key: 'instagram', icon: 'fab fa-instagram', label: 'Instagram' },
      { key: 'twitter', icon: 'fab fa-x-twitter', label: 'X/Twitter' },
      { key: 'facebook', icon: 'fab fa-facebook-f', label: 'Facebook' },
      { key: 'github', icon: 'fab fa-github', label: 'GitHub' },
      { key: 'youtube', icon: 'fab fa-youtube', label: 'YouTube' },
      { key: 'tiktok', icon: 'fab fa-tiktok', label: 'TikTok' },
      ].filter(s => card[s.key]); %>

    <% if (socials.length > 0) { %>
      <div class="social-links">
        <% socials.forEach(s => { %>
          <a href="<%= card[s.key] %>" target="_blank" class="social-link" aria-label="<%= s.label %>">
            <i class="<%= s.icon %>"></i>
          </a>
        <% }) %>
      </div>
    <% } %>

    <!-- QR Code -->
    <section class="qr-section">
      <p class="qr-label">Scan to View Card</p>
      <div id="qrcode"></div>
    </section>

    <!-- Footer Branding -->
    <% if (card.brand_name) { %>
      <div class="branding">
        <% if (card.company_highlight && card.brand_name.includes(card.company_highlight)) {
          const parts = card.brand_name.split(card.company_highlight);
        %>
          <div class="bogen-logo"><%= parts[0] %><span><%= card.company_highlight %></span><%= parts[1] || '' %></div>
        <% } else { %>
          <div class="bogen-logo"><%= card.brand_name %></div>
        <% } %>
        <% if (card.brand_tagline) { %><p class="tagline"><%= card.brand_tagline %></p><% } %>
      </div>
    <% } %>
  </div>

  <!-- iOS Add to Home Screen modal -->
  <div id="ios-modal" style="display:none; position:fixed; inset:0; z-index:200; align-items:flex-end; justify-content:center; background:rgba(0,0,0,0.5);">
    <div style="background:#fff; color:#1a1a1a; border-radius:20px 20px 0 0; padding:28px 24px 36px; width:100%; max-width:420px; font-family:'Montserrat',sans-serif;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <span style="font-size:15px; font-weight:700; letter-spacing:0.03em;">Add to Home Screen</span>
        <button onclick="document.getElementById('ios-modal').style.display='none'" style="background:none;border:none;font-size:22px;cursor:pointer;color:#888;line-height:1;">×</button>
      </div>
      <div style="display:flex; align-items:flex-start; gap:16px; margin-bottom:16px;">
        <div style="background:var(--bright-blue);border-radius:10px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <span style="font-size:20px;">1</span>
        </div>
        <div>
          <p style="font-size:14px; font-weight:600; margin-bottom:4px;">Tap the Share button</p>
          <p style="font-size:12px; color:#666;">Find <i class="fas fa-arrow-up-from-bracket"></i> at the bottom of your Safari browser</p>
        </div>
      </div>
      <div style="display:flex; align-items:flex-start; gap:16px; margin-bottom:24px;">
        <div style="background:var(--bright-blue);border-radius:10px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <span style="font-size:20px;">2</span>
        </div>
        <div>
          <p style="font-size:14px; font-weight:600; margin-bottom:4px;">Tap "Add to Home Screen"</p>
          <p style="font-size:12px; color:#666;">Scroll down in the share sheet and tap <strong>Add to Home Screen</strong></p>
        </div>
      </div>
      <div style="border-top:1px solid #eee; padding-top:16px; text-align:center;">
        <p style="font-size:11px; color:#aaa; letter-spacing:0.05em; text-transform:uppercase;">Only available in Safari on iPhone & iPad</p>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    const cardPhones = <%- JSON.stringify(card.phones || []) %>;
    const cardEmails = <%- JSON.stringify(card.emails || []) %>;
    const cardWebsites = <%- JSON.stringify(card.websites || (card.website ? [{ label: 'Website', value: card.website }] : [])) %>;

    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2500);
    }

    function sendCard() {
      const url = window.location.href;
      const msg = 'Hey! Here\'s my digital business card: ' + url;
      window.location.href = 'sms:?&body=' + encodeURIComponent(msg);
    }

    document.addEventListener('DOMContentLoaded', function() {
      new QRCode(document.getElementById('qrcode'), {
        text: window.location.href,
        width: 120, height: 120,
        colorDark: '<%= card.light_theme ? "#1a1a1a" : (card.secondary_color || "#1a3e5c") %>',
        colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.H
      });
    });

    // ── Add to Home Screen ──
    (function() {
      const ua = navigator.userAgent;
      const isIOS = /iphone|ipad|ipod/i.test(ua);
      const isAndroid = /android/i.test(ua);
      const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;

      if (isStandalone) return; // already installed

      if (isIOS) {
        const btn = document.getElementById('install-btn');
        document.getElementById('install-icon').className = 'fas fa-arrow-up-from-bracket';
        document.getElementById('install-label').textContent = 'Add to Home Screen';
        btn.style.display = 'block';
      }

      if (isAndroid) {
        window.addEventListener('beforeinstallprompt', function(e) {
          e.preventDefault();
          window._pwaPrompt = e;
          const btn = document.getElementById('install-btn');
          document.getElementById('install-icon').className = 'fab fa-android';
          document.getElementById('install-label').textContent = 'Add to Home Screen';
          btn.style.display = 'block';
        });
      }
    })();

    function handleInstall() {
      const ua = navigator.userAgent;
      if (/iphone|ipad|ipod/i.test(ua)) {
        document.getElementById('ios-modal').style.display = 'flex';
      } else if (window._pwaPrompt) {
        window._pwaPrompt.prompt();
        window._pwaPrompt.userChoice.then(function(result) {
          if (result.outcome === 'accepted') {
            document.getElementById('install-btn').style.display = 'none';
          }
          window._pwaPrompt = null;
        });
      }
    }

    // Register service worker (required for Android PWA prompt)
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(function() {});
    }

    function downloadVCard() {
      const v = `BEGIN:VCARD
VERSION:3.0
N:<%= (card.name || '').split(' ').reverse().join(';') %>;;;
FN:<%= card.name || '' %>
<% if (card.company) { %>ORG:<%= card.company %><% } %>
<% if (card.title) { %>TITLE:<%= card.title %><% } %>
${cardPhones.map(p => `TEL;TYPE=${p.whatsapp ? 'CELL' : 'WORK'}:${p.value}`).join('\n')}
${cardEmails.map(e => `EMAIL;TYPE=WORK:${e.value}`).join('\n')}
<% if (card.location) { %>ADR;TYPE=WORK:;;<%= card.location %>;;;;<% } %>
${cardWebsites.map(w => `URL:${w.value}`).join('\n')}
<% if (card.linkedin) { %>X-SOCIALPROFILE;TYPE=linkedin:<%= card.linkedin %><% } %>
<% if (card.instagram) { %>X-SOCIALPROFILE;TYPE=instagram:<%= card.instagram %><% } %>
<% if (card.twitter) { %>X-SOCIALPROFILE;TYPE=twitter:<%= card.twitter %><% } %>
END:VCARD`;

      const blob = new Blob([v], { type: 'text/vcard;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = '<%= (card.name || "contact").replace(/\s+/g, "_") %>.vcf';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      showToast('Contact saved!');
    }
  </script>
</body>
</html>
