<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Card | Business Card Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <nav class="navbar">
    <a href="/dashboard" class="nav-brand">
      <img src="https://res.cloudinary.com/dv8wehdd1/image/upload/v1773092815/business-cards/brand/bogen-ai-logo.png" alt="Bogen.ai">
    </a>
    <div class="nav-links">
      <a href="/<%= card.slug %>" target="_blank" class="preview-link" style="color:rgba(255,255,255,0.8);">
        <i class="fas fa-eye"></i> View My Card
      </a>
      <form method="POST" action="/logout" style="display:inline;">
        <button type="submit" class="btn-logout"><i class="fas fa-sign-out-alt"></i> Logout</button>
      </form>
    </div>
  </nav>

  <div class="page">
    <div class="page-header">
      <div>
        <h1 class="page-title">My Business Card</h1>
        <a href="/<%= card.slug %>" target="_blank" class="preview-link">
          <i class="fas fa-external-link-alt"></i> yoursite.com/<%= card.slug %>
        </a>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>

    <form method="POST" action="/dashboard/edit">
      <div class="form-card">

        <!-- Images -->
        <div class="form-section">
          <div class="form-section-title"><i class="fas fa-images"></i> Images</div>

          <div class="images-layout">
            <!-- Headshot -->
            <div class="image-block">
              <label class="image-block-label">Headshot Photo</label>
              <div class="upload-area">
                <% if (card.headshot_url) { %>
                  <img src="<%= card.headshot_url %>" id="headshot-preview" class="headshot-preview">
                <% } else { %>
                  <div class="upload-placeholder round" id="headshot-preview"><i class="fas fa-user"></i></div>
                <% } %>
                <label for="headshot-input" class="btn btn-secondary btn-sm" style="cursor:pointer;">
                  <i class="fas fa-upload"></i> Upload Photo
                </label>
                <input type="file" id="headshot-input" accept="image/*" style="display:none" onchange="uploadImage(this, 'headshot')">
                <span class="upload-status" id="headshot-status"></span>
              </div>
            </div>

            <!-- Logo -->
            <div class="image-block logo-block">
              <label class="image-block-label">Brand Logo</label>
              <input type="hidden" name="logo_invert" id="logo_invert" value="<%= card.logo_invert || '' %>">

              <div id="logo-versions" style="display:<%= card.logo_url ? 'flex' : 'none' %>; gap:12px; margin-bottom:12px;">
                <div class="logo-option <%= (!card.logo_invert || card.logo_invert === '') ? 'selected' : '' %>" onclick="selectLogoVersion('')">
                  <div class="logo-option-label">Original</div>
                  <div class="logo-option-bg light">
                    <img src="<%= card.logo_url || '' %>" class="logo-option-img" id="logo-orig">
                  </div>
                </div>
                <div class="logo-option <%= card.logo_invert === 'auto' ? 'selected' : '' %>" onclick="selectLogoVersion('auto')">
                  <div class="logo-option-label">Auto Inverted</div>
                  <div class="logo-option-bg dark">
                    <img src="<%= card.logo_url || '' %>" class="logo-option-img" style="filter:invert(1)" id="logo-auto-inv">
                  </div>
                </div>
                <div class="logo-option <%= card.logo_invert === 'custom' ? 'selected' : '' %>" onclick="selectLogoVersion('custom')">
                  <div class="logo-option-label">Custom Inverted</div>
                  <div class="logo-option-bg dark">
                    <% if (card.logo_inverted_url) { %>
                      <img src="<%= card.logo_inverted_url %>" class="logo-option-img" id="logo-custom-img">
                    <% } else { %>
                      <span id="logo-custom-img" style="font-size:10px;color:rgba(255,255,255,0.5);text-align:center;line-height:1.3;">Upload<br>custom</span>
                    <% } %>
                  </div>
                </div>
              </div>

              <% if (!card.logo_url) { %>
                <div class="upload-placeholder" id="logo-placeholder" style="margin-bottom:10px;"><i class="fas fa-image"></i></div>
              <% } %>

              <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
                <label for="logo-input" class="btn btn-secondary btn-sm" style="cursor:pointer;">
                  <i class="fas fa-upload"></i> Upload Logo
                </label>
                <input type="file" id="logo-input" accept="image/*" style="display:none" onchange="uploadImage(this, 'logo')">
                <span class="upload-status" id="logo-status"></span>
                <% if (card.logo_url) { %>
                  <label for="logo-inverted-input" class="btn btn-secondary btn-sm" style="cursor:pointer;">
                    <i class="fas fa-upload"></i> Upload Custom Inverted
                  </label>
                  <input type="file" id="logo-inverted-input" accept="image/*" style="display:none" onchange="uploadInvertedLogo(this)">
                  <span class="upload-status" id="logo-inverted-status"></span>
                <% } %>
              </div>

              <div style="margin-top:14px;">
                <label style="font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#6c757d;">Logo Size: <span id="logo-size-label"><%= card.logo_size || 60 %>px</span></label>
                <div style="display:flex; align-items:center; gap:10px; margin-top:6px;">
                  <span style="font-size:11px; color:#adb5bd;">S</span>
                  <input type="range" name="logo_size" min="30" max="150" value="<%= card.logo_size || 60 %>" style="flex:1; accent-color:#00a8e1;" oninput="updateLogoSize(this.value)">
                  <span style="font-size:11px; color:#adb5bd;">L</span>
                </div>
              </div>
            </div>
          </div>

          <p style="font-size:12px; color:#6c757d; margin-top:12px;"><i class="fas fa-info-circle"></i> Images are saved immediately on upload. Max 5MB.</p>
        </div>

        <!-- Profile -->
        <div class="form-section">
          <div class="form-section-title"><i class="fas fa-id-badge"></i> Profile</div>
          <div class="form-grid">
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" value="<%= card.name || '' %>" placeholder="John Smith">
            </div>
            <div class="form-group">
              <label for="title">Job Title</label>
              <input type="text" id="title" name="title" value="<%= card.title || '' %>" placeholder="CEO & Founder">
            </div>
            <div class="form-group">
              <label for="company">Company Name</label>
              <input type="text" id="company" name="company" value="<%= card.company || '' %>" placeholder="Acme Inc">
            </div>
            <div class="form-group">
              <label for="company_highlight">Company Highlight (colored portion)</label>
              <input type="text" id="company_highlight" name="company_highlight" value="<%= card.company_highlight || '' %>" placeholder=".ai">
            </div>
          </div>
        </div>

        <!-- Contact -->
        <div class="form-section">
          <div class="form-section-title"><i class="fas fa-address-book"></i> Contact</div>
          <div class="form-grid cols-1">
            <div class="form-group">
              <label for="location">Location</label>
              <input type="text" id="location" name="location" value="<%= card.location || '' %>" placeholder="Miami Beach, FL">
            </div>
          </div>

          <!-- Websites -->
          <div style="margin-top:20px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
              <label style="font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#6c757d;">Websites</label>
              <button type="button" class="btn btn-secondary btn-sm" onclick="addWebsite()"><i class="fas fa-plus"></i> Add Website</button>
            </div>
            <div id="websites-container">
              <% const websites = (card && card.websites) ? (typeof card.websites === 'string' ? JSON.parse(card.websites) : card.websites) : []; %>
              <% if (websites.length === 0) { %>
                <div class="multi-row" data-type="website">
                  <input type="text" name="website_label[]" placeholder="Label (e.g. Main)" value="Website" class="multi-label">
                  <input type="text" name="website_value[]" placeholder="https://example.com" class="multi-value website-url" onblur="fixUrl(this)">
                  <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)"><i class="fas fa-times"></i></button>
                </div>
              <% } else { %>
                <% websites.forEach(w => { %>
                  <div class="multi-row" data-type="website">
                    <input type="text" name="website_label[]" placeholder="Label" value="<%= w.label || '' %>" class="multi-label">
                    <input type="text" name="website_value[]" placeholder="https://example.com" value="<%= w.value || '' %>" class="multi-value website-url" onblur="fixUrl(this)">
                    <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)"><i class="fas fa-times"></i></button>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>

          <!-- Emails -->
          <div style="margin-top:20px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
              <label style="font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#6c757d;">Email Addresses</label>
              <button type="button" class="btn btn-secondary btn-sm" onclick="addEmail()"><i class="fas fa-plus"></i> Add Email</button>
            </div>
            <div id="emails-container">
              <% const emails = (card && card.emails) ? (typeof card.emails === 'string' ? JSON.parse(card.emails) : card.emails) : []; %>
              <% if (emails.length === 0) { %>
                <div class="multi-row" data-type="email">
                  <input type="text" name="email_label[]" placeholder="Label (e.g. Work)" value="Work" class="multi-label">
                  <input type="email" name="email_value[]" placeholder="email@example.com" class="multi-value">
                  <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)"><i class="fas fa-times"></i></button>
                </div>
              <% } else { %>
                <% emails.forEach(e => { %>
                  <div class="multi-row" data-type="email">
                    <input type="text" name="email_label[]" placeholder="Label" value="<%= e.label || '' %>" class="multi-label">
                    <input type="email" name="email_value[]" placeholder="email@example.com" value="<%= e.value || '' %>" class="multi-value">
                    <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)"><i class="fas fa-times"></i></button>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>

          <!-- Phones -->
          <div style="margin-top:20px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
              <label style="font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#6c757d;">Phone Numbers</label>
              <button type="button" class="btn btn-secondary btn-sm" onclick="addPhone()"><i class="fas fa-plus"></i> Add Phone</button>
            </div>
            <div id="phones-container">
              <% const phones = (card && card.phones) ? (typeof card.phones === 'string' ? JSON.parse(card.phones) : card.phones) : []; %>
              <% if (phones.length === 0) { %>
                <div class="multi-row" data-type="phone">
                  <input type="text" name="phone_label[]" placeholder="Label (e.g. Mobile)" value="Mobile" class="multi-label">
                  <input type="tel" name="phone_value[]" placeholder="+1 (305) 000-0000" class="multi-value">
                  <label class="whatsapp-toggle"><input type="checkbox" name="phone_whatsapp[]"> <i class="fab fa-whatsapp"></i> WhatsApp</label>
                  <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)"><i class="fas fa-times"></i></button>
                </div>
              <% } else { %>
                <% phones.forEach(p => { %>
                  <div class="multi-row" data-type="phone">
                    <input type="text" name="phone_label[]" placeholder="Label" value="<%= p.label || '' %>" class="multi-label">
                    <input type="tel" name="phone_value[]" placeholder="+1 (305) 000-0000" value="<%= p.value || '' %>" class="multi-value">
                    <label class="whatsapp-toggle"><input type="checkbox" name="phone_whatsapp[]" <%= p.whatsapp ? 'checked' : '' %>> <i class="fab fa-whatsapp"></i> WhatsApp</label>
                    <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)"><i class="fas fa-times"></i></button>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Design -->
        <div class="form-section">
          <div class="form-section-title"><i class="fas fa-palette"></i> Design</div>

          <!-- Theme presets -->
          <div style="margin-bottom:20px;">
            <label style="font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#6c757d; display:block; margin-bottom:10px;">Theme Presets</label>
            <div style="display:flex; gap:10px; flex-wrap:wrap;">
              <button type="button" class="theme-btn" onclick="applyTheme('#00a8e1','#1a3e5c','#1a3e5c','#0d2233','#00a8e1')" style="background:linear-gradient(135deg,#1a3e5c,#0d2233);">Ocean</button>
              <button type="button" class="theme-btn" onclick="applyTheme('#a855f7','#1a0533','#1a0533','#0d0019','#a855f7')" style="background:linear-gradient(135deg,#1a0533,#0d0019);">Midnight</button>
              <button type="button" class="theme-btn" onclick="applyTheme('#22c55e','#052e16','#052e16','#021a0d','#22c55e')" style="background:linear-gradient(135deg,#052e16,#021a0d);">Forest</button>
              <button type="button" class="theme-btn" onclick="applyTheme('#f59e0b','#1c1917','#1c1917','#0c0a09','#f59e0b')" style="background:linear-gradient(135deg,#1c1917,#0c0a09);">Ember</button>
              <button type="button" class="theme-btn" onclick="applyTheme('#ef4444','#1f0505','#1f0505','#0d0000','#ef4444')" style="background:linear-gradient(135deg,#1f0505,#0d0000);">Crimson</button>
              <button type="button" class="theme-btn" onclick="applyTheme('#64748b','#1e293b','#1e293b','#0f172a','#64748b')" style="background:linear-gradient(135deg,#1e293b,#0f172a);">Slate</button>
              <button type="button" class="theme-btn" onclick="applyTheme('#ffffff','#111111','#111111','#000000','#ffffff')" style="background:linear-gradient(135deg,#111111,#000000);">Noir</button>
            </div>
          </div>

          <!-- Color pickers -->
          <div class="form-grid">
            <div class="form-group">
              <label>Accent / Highlight Color</label>
              <div style="display:flex;align-items:center;gap:8px;">
                <input type="color" name="primary_color" id="primary_color" value="<%= card ? (card.primary_color || '#00a8e1') : '#00a8e1' %>" oninput="updatePreview()">
                <input type="text" id="primary_color_hex" value="<%= card ? (card.primary_color || '#00a8e1') : '#00a8e1' %>" style="width:90px;" oninput="syncColor('primary_color',this.value)">
              </div>
            </div>
            <div class="form-group">
              <label>Background Top</label>
              <div style="display:flex;align-items:center;gap:8px;">
                <input type="color" name="bg_color_start" id="bg_color_start" value="<%= card ? (card.bg_color_start || '#1a3e5c') : '#1a3e5c' %>" oninput="updatePreview()">
                <input type="text" id="bg_color_start_hex" value="<%= card ? (card.bg_color_start || '#1a3e5c') : '#1a3e5c' %>" style="width:90px;" oninput="syncColor('bg_color_start',this.value)">
              </div>
            </div>
            <div class="form-group">
              <label>Background Bottom</label>
              <div style="display:flex;align-items:center;gap:8px;">
                <input type="color" name="bg_color_end" id="bg_color_end" value="<%= card ? (card.bg_color_end || '#0d2233') : '#0d2233' %>" oninput="updatePreview()">
                <input type="text" id="bg_color_end_hex" value="<%= card ? (card.bg_color_end || '#0d2233') : '#0d2233' %>" style="width:90px;" oninput="syncColor('bg_color_end',this.value)">
              </div>
            </div>
            <div class="form-group">
              <label>Accent Bar</label>
              <div style="display:flex;align-items:center;gap:8px;">
                <input type="color" name="accent_bar_color" id="accent_bar_color" value="<%= card ? (card.accent_bar_color || '#00a8e1') : '#00a8e1' %>" oninput="updatePreview()">
                <input type="text" id="accent_bar_color_hex" value="<%= card ? (card.accent_bar_color || '#00a8e1') : '#00a8e1' %>" style="width:90px;" oninput="syncColor('accent_bar_color',this.value)">
              </div>
            </div>
          </div>

          <!-- Live preview -->
          <div style="margin-top:16px;">
            <label style="font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#6c757d; display:block; margin-bottom:8px;">Preview</label>
            <div id="design-preview" style="width:180px;height:100px;border-radius:8px;position:relative;overflow:hidden;box-shadow:0 4px 16px rgba(0,0,0,0.2);">
              <div id="preview-bg" style="position:absolute;inset:0;"></div>
              <div id="preview-bar" style="position:absolute;left:0;top:0;width:4px;height:100%;"></div>
              <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;">
                <div id="preview-dot" style="width:28px;height:28px;border-radius:50%;border:2px solid;"></div>
                <div id="preview-line1" style="width:60px;height:4px;border-radius:2px;background:rgba(255,255,255,0.9);"></div>
                <div id="preview-line2" style="width:40px;height:3px;border-radius:2px;opacity:0.6;"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Social -->
        <div class="form-section">
          <div class="form-section-title"><i class="fas fa-share-alt"></i> Social Links</div>
          <div class="form-grid cols-3">
            <div class="form-group">
              <label><i class="fab fa-linkedin"></i> LinkedIn</label>
              <input type="url" name="linkedin" value="<%= card.linkedin || '' %>" placeholder="https://linkedin.com/in/...">
            </div>
            <div class="form-group">
              <label><i class="fab fa-instagram"></i> Instagram</label>
              <input type="url" name="instagram" value="<%= card.instagram || '' %>" placeholder="https://instagram.com/...">
            </div>
            <div class="form-group">
              <label><i class="fab fa-x-twitter"></i> X / Twitter</label>
              <input type="url" name="twitter" value="<%= card.twitter || '' %>" placeholder="https://x.com/...">
            </div>
            <div class="form-group">
              <label><i class="fab fa-facebook"></i> Facebook</label>
              <input type="url" name="facebook" value="<%= card.facebook || '' %>" placeholder="https://facebook.com/...">
            </div>
            <div class="form-group">
              <label><i class="fab fa-github"></i> GitHub</label>
              <input type="url" name="github" value="<%= card.github || '' %>" placeholder="https://github.com/...">
            </div>
            <div class="form-group">
              <label><i class="fab fa-youtube"></i> YouTube</label>
              <input type="url" name="youtube" value="<%= card.youtube || '' %>" placeholder="https://youtube.com/...">
            </div>
            <div class="form-group">
              <label><i class="fab fa-tiktok"></i> TikTok</label>
              <input type="url" name="tiktok" value="<%= card.tiktok || '' %>" placeholder="https://tiktok.com/@...">
            </div>
          </div>
        </div>

        <!-- Branding -->
        <div class="form-section">
          <div class="form-section-title"><i class="fas fa-trademark"></i> Footer Branding</div>
          <div class="form-grid">
            <div class="form-group">
              <label for="brand_name">Brand Name</label>
              <input type="text" id="brand_name" name="brand_name" value="<%= card.brand_name || '' %>" placeholder="Bogen.ai">
            </div>
            <div class="form-group">
              <label for="brand_tagline">Tagline</label>
              <input type="text" id="brand_tagline" name="brand_tagline" value="<%= card.brand_tagline || '' %>" placeholder="AI Automation Services">
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Save Changes
          </button>
          <a href="/<%= card.slug %>" target="_blank" class="btn btn-secondary" style="margin-left:auto;">
            <i class="fas fa-external-link-alt"></i> View My Card
          </a>
        </div>
      </div>
    </form>
  </div>

  <style>
    .upload-area { display:flex; flex-direction:column; align-items:flex-start; gap:8px; }
    .images-layout { display:flex; gap:40px; align-items:flex-start; flex-wrap:wrap; }
    .image-block { display:flex; flex-direction:column; gap:10px; }
    .image-block-label { font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#6c757d; }
    .headshot-preview { width:120px; height:120px; border-radius:50%; object-fit:cover; border:2px solid #e9ecef; }
    .upload-placeholder { width:120px; height:120px; border-radius:8px; border:2px dashed #dee2e6; display:flex; align-items:center; justify-content:center; font-size:32px; color:#adb5bd; background:#f8f9fa; }
    .upload-placeholder.round { border-radius:50%; }
    .upload-status { font-size:12px; font-weight:500; }
    .upload-status.success { color:#28a745; }
    .upload-status.error { color:#dc3545; }
    .upload-status.loading { color:#00a8e1; }
    .logo-block { flex:1; min-width:300px; }
    .logo-option { display:flex; flex-direction:column; align-items:center; gap:6px; cursor:pointer; }
    .logo-option-label { font-size:11px; font-weight:600; letter-spacing:0.05em; text-transform:uppercase; color:#6c757d; white-space:nowrap; }
    .logo-option-bg { width:110px; height:80px; border-radius:8px; display:flex; align-items:center; justify-content:center; border:2px solid #e9ecef; padding:8px; transition:border-color 0.2s; }
    .logo-option-bg.light { background:#ffffff; }
    .logo-option-bg.dark { background:#1a3e5c; }
    .logo-option-img { max-width:90px; max-height:60px; object-fit:contain; }
    .logo-option.selected .logo-option-bg { border-color:#00a8e1; box-shadow:0 0 0 3px rgba(0,168,225,0.2); }
    .logo-option:hover .logo-option-bg { border-color:#00a8e1; }
    .multi-row { display:flex; align-items:center; gap:8px; margin-bottom:8px; flex-wrap:wrap; }
    .multi-label { width:130px; flex-shrink:0; }
    .multi-value { flex:1; min-width:160px; }
    .whatsapp-toggle { display:flex; align-items:center; gap:5px; font-size:13px; font-weight:500; color:#25d366; white-space:nowrap; cursor:pointer; }
    .whatsapp-toggle input { accent-color:#25d366; }
    .theme-btn { padding:8px 14px; border:2px solid rgba(255,255,255,0.2); border-radius:6px; color:#fff; font-size:12px; font-weight:600; cursor:pointer; letter-spacing:0.05em; transition:all 0.2s; }
    .theme-btn:hover { border-color:#fff; transform:translateY(-1px); }
  </style>

  <script>
    async function uploadImage(input, type) {
      const file = input.files[0];
      if (!file) return;
      const statusEl = document.getElementById(type + '-status');
      const previewEl = document.getElementById(type + '-preview');
      statusEl.textContent = 'Uploading...';
      statusEl.className = 'upload-status loading';

      const formData = new FormData();
      formData.append(type, file);

      try {
        const res = await fetch(`/dashboard/upload-${type}`, { method: 'POST', body: formData });
        const data = await res.json();
        if (data.url) {
          if (type === 'logo') {
            showLogoPreviews(data.url);
          } else if (previewEl.tagName === 'IMG') {
            previewEl.src = data.url;
          } else {
            const img = document.createElement('img');
            img.src = data.url;
            img.id = type + '-preview';
            img.className = 'upload-preview';
            previewEl.replaceWith(img);
          }
          statusEl.textContent = '✓ Uploaded successfully';
          statusEl.className = 'upload-status success';
        } else {
          throw new Error(data.error || 'Upload failed');
        }
      } catch (err) {
        statusEl.textContent = '✗ ' + err.message;
        statusEl.className = 'upload-status error';
      }
    }

    function updateLogoSize(val) {
      document.getElementById('logo-size-label').textContent = val + 'px';
      document.querySelectorAll('.logo-option-img').forEach(img => {
        img.style.maxHeight = val + 'px';
      });
    }

    function selectLogoVersion(val) {
      document.getElementById('logo_invert').value = val;
      document.querySelectorAll('.logo-option').forEach(el => {
        el.classList.toggle('selected', el.getAttribute('onclick') === `selectLogoVersion('${val}')`);
      });
    }

    function showLogoPreviews(url) {
      document.getElementById('logo-orig').src = url;
      document.getElementById('logo-auto-inv').src = url;
      document.getElementById('logo-versions').style.display = 'flex';
      const placeholder = document.getElementById('logo-placeholder');
      if (placeholder) placeholder.style.display = 'none';
    }

    function addEmail() {
      const container = document.getElementById('emails-container');
      const row = document.createElement('div');
      row.className = 'multi-row';
      row.setAttribute('data-type', 'email');
      row.innerHTML = `
        <input type="text" name="email_label[]" placeholder="Label (e.g. Work)" value="Work" class="multi-label">
        <input type="email" name="email_value[]" placeholder="email@example.com" class="multi-value">
        <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)"><i class="fas fa-times"></i></button>
      `;
      container.appendChild(row);
    }

    function addPhone() {
      const container = document.getElementById('phones-container');
      const row = document.createElement('div');
      row.className = 'multi-row';
      row.setAttribute('data-type', 'phone');
      row.innerHTML = `
        <input type="text" name="phone_label[]" placeholder="Label (e.g. Mobile)" value="Mobile" class="multi-label">
        <input type="tel" name="phone_value[]" placeholder="+1 (305) 000-0000" class="multi-value">
        <label class="whatsapp-toggle"><input type="checkbox" name="phone_whatsapp[]"> <i class="fab fa-whatsapp"></i> WhatsApp</label>
        <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)"><i class="fas fa-times"></i></button>
      `;
      container.appendChild(row);
    }

    function addWebsite() {
      const container = document.getElementById('websites-container');
      const row = document.createElement('div');
      row.className = 'multi-row';
      row.setAttribute('data-type', 'website');
      row.innerHTML = `
        <input type="text" name="website_label[]" placeholder="Label (e.g. Blog)" value="Website" class="multi-label">
        <input type="text" name="website_value[]" placeholder="https://example.com" class="multi-value website-url" onblur="fixUrl(this)">
        <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)"><i class="fas fa-times"></i></button>
      `;
      container.appendChild(row);
    }

    function fixUrl(input) {
      const v = input.value.trim();
      if (v && !v.match(/^https?:\/\//i)) {
        input.value = 'https://' + v;
      }
    }

    document.querySelectorAll('.website-url').forEach(el => el.addEventListener('blur', () => fixUrl(el)));

    function removeRow(btn) {
      btn.closest('.multi-row').remove();
    }

    async function uploadInvertedLogo(input) {
      const file = input.files[0];
      if (!file) return;
      const statusEl = document.getElementById('logo-inverted-status');
      statusEl.textContent = 'Uploading...';
      statusEl.className = 'upload-status loading';
      const formData = new FormData();
      formData.append('logo_inverted', file);
      try {
        const res = await fetch('/dashboard/upload-logo-inverted', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.url) {
          const imgEl = document.getElementById('logo-custom-img');
          if (imgEl.tagName === 'IMG') {
            imgEl.src = data.url;
          } else {
            const img = document.createElement('img');
            img.src = data.url;
            img.className = 'logo-option-img';
            img.id = 'logo-custom-img';
            imgEl.replaceWith(img);
          }
          selectLogoVersion('custom');
          statusEl.textContent = '✓ Uploaded';
          statusEl.className = 'upload-status success';
        } else throw new Error(data.error);
      } catch(err) {
        statusEl.textContent = '✗ ' + err.message;
        statusEl.className = 'upload-status error';
      }
    }

    function applyTheme(primary, secondary, bgStart, bgEnd, accent) {
      document.getElementById('primary_color').value = primary;
      document.getElementById('primary_color_hex').value = primary;
      document.getElementById('bg_color_start').value = bgStart;
      document.getElementById('bg_color_start_hex').value = bgStart;
      document.getElementById('bg_color_end').value = bgEnd;
      document.getElementById('bg_color_end_hex').value = bgEnd;
      document.getElementById('accent_bar_color').value = accent;
      document.getElementById('accent_bar_color_hex').value = accent;
      updatePreview();
    }

    function syncColor(id, val) {
      if (/^#[0-9a-fA-F]{6}$/.test(val)) {
        document.getElementById(id).value = val;
        updatePreview();
      }
    }

    function updatePreview() {
      const primary = document.getElementById('primary_color').value;
      const bgStart = document.getElementById('bg_color_start').value;
      const bgEnd = document.getElementById('bg_color_end').value;
      const accent = document.getElementById('accent_bar_color').value;
      document.getElementById('preview-bg').style.background = `linear-gradient(180deg, ${bgStart} 0%, ${bgEnd} 100%)`;
      document.getElementById('preview-bar').style.background = accent;
      document.getElementById('preview-dot').style.borderColor = primary;
      document.getElementById('preview-line2').style.background = primary;
    }

    updatePreview();
  </script>
</body>
</html>
